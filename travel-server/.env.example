## WayTrip 后端环境变量模板
## 使用方式：
## 1. 复制当前文件为 .env
## 2. 按你的本地或服务器环境填写实际值
## 3. .env 只供当前环境使用，不提交到 Git

## 数据库配置
DB_HOST=localhost
DB_PORT=3306
DB_NAME=waytrip_db
DB_USERNAME=root
DB_PASSWORD=

## Redis 配置
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_CLIENT_NAME=waytrip-prod
REDIS_POOL_MAX_ACTIVE=32
REDIS_POOL_MAX_IDLE=16
REDIS_POOL_MIN_IDLE=4

## JWT 配置
## 用于签名 Token 的密钥，建议至少 32 个字符
JWT_SECRET=

## 应用级缓存与任务配置
## 不改也能直接运行；只有在你需要调整生产环境缓存策略或定时任务时间时再修改。
APP_CACHE_RECOMMENDATION_USER_REC_TTL_MINUTES=60
APP_CACHE_RECOMMENDATION_SIMILARITY_TTL_HOURS=24
APP_CACHE_HOME_HOT_SPOTS_TTL_MINUTES=10
APP_CACHE_HOME_BANNERS_TTL_MINUTES=10
APP_TASK_SPOT_HEAT_SYNC_CRON=0 30 3 * * ?

## AI 三段模型配置
## 默认推荐：
## 1. 最终生成走 OpenAI 兼容接口
## 2. 意图识别走本地 Ollama
## 3. 知识库 embedding 走本地 Ollama
## 注意：切换 embedding 模型后，需要清空并重建知识库向量，避免新旧向量空间不一致。

## 生成模型：负责最终答案生成
APP_AI_GENERATION_PROVIDER=openai
APP_AI_GENERATION_MODEL=qwen3.5-plus
APP_AI_GENERATION_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
APP_AI_GENERATION_API_KEY=
APP_AI_GENERATION_COMPLETIONS_PATH=/chat/completions
APP_AI_GENERATION_TEMPERATURE=0.2

## 意图模型：负责意图识别与槽位提取
APP_AI_INTENT_PROVIDER=ollama
APP_AI_INTENT_MODEL=qwen2.5:1.5b
APP_AI_INTENT_BASE_URL=http://127.0.0.1:11434
APP_AI_INTENT_TEMPERATURE=0.0

## 嵌入模型：负责知识入库与查询向量化
APP_AI_EMBEDDING_PROVIDER=ollama
APP_AI_EMBEDDING_MODEL=nomic-embed-text
APP_AI_EMBEDDING_BASE_URL=http://127.0.0.1:11434
APP_AI_EMBEDDING_PATH=/v1/embeddings
APP_AI_EMBEDDING_API_KEY=

## 兼容 OpenAI 风格接口时可复用的基础地址与密钥
OPENAI_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
OPENAI_API_KEY=

## 兼容 Ollama 的统一基础地址
OLLAMA_BASE_URL=http://127.0.0.1:11434

## AI 通用参数
APP_AI_CHAT_TIMEOUT_SECONDS=60
APP_AI_CHAT_TEMPERATURE=0.2
APP_AI_CHAT_MAX_INPUT_LENGTH=800
APP_AI_CHAT_MAX_HISTORY_ROUNDS=8
## 默认开启 RAG，方便直接联调 AI 客服知识检索链路。
## 如果你只想验证纯对话生成，可临时改为 false。
APP_AI_RAG_ENABLED=true
APP_AI_RAG_TOP_K=4
APP_AI_RAG_MIN_SCORE=0.65
## 向量库 Redis 可以和业务 Redis 共用，也可以单独使用一个实例或端口。
## 当前模板默认使用独立端口 6380，避免和业务缓存空间混用。
APP_AI_VECTOR_REDIS_HOST=127.0.0.1
APP_AI_VECTOR_REDIS_PORT=6380
APP_AI_VECTOR_REDIS_PASSWORD=
APP_AI_VECTOR_REDIS_CLIENT_NAME=waytrip-ai-vector
APP_AI_VECTOR_REDIS_TIMEOUT_SECONDS=3
APP_AI_VECTOR_REDIS_SSL_ENABLED=false
APP_AI_VECTOR_REDIS_INDEX_NAME=waytrip-ai-knowledge-index
APP_AI_VECTOR_REDIS_PREFIX=waytrip:ai:chunk:
APP_AI_VECTOR_REDIS_INITIALIZE_SCHEMA=true
APP_AI_VECTOR_REDIS_ALGORITHM=HNSW
APP_AI_MEMORY_TTL_MINUTES=60
APP_AI_MEMORY_HISTORY_ROUNDS=8
APP_AI_MEMORY_SUMMARY_ENABLED=true
APP_AI_GUARDRAIL_RATE_LIMIT_IP_PER_MINUTE=24
APP_AI_GUARDRAIL_RATE_LIMIT_SESSION_PER_MINUTE=12
APP_AI_METRICS_ENABLED=true

## 微信小程序配置
## 从微信公众平台获取
## 同时需要在 travel-miniapp/src/manifest.json 中更新 appid
WECHAT_APPID=
WECHAT_SECRET=

## 文件上传配置
## 建议优先使用绝对路径，避免因启动工作目录不同导致相对路径解析结果不一致
## 如果使用相对路径：
## - 从 WayTrip 根目录启动时，相对 WayTrip 根目录解析
## - 从 travel-server 目录启动时，相对 travel-server 目录解析
UPLOAD_PATH=E:/path/to/waytrip/uploads

## 日志配置（通过环境变量或 JVM 参数，可选）
## LOG_HOME 表示日志根目录；不配置时默认使用 ./travel-server/logs
## 服务日志写入 ${LOG_HOME}/server，AI 日志写入 ${LOG_HOME}/ai
##
## 配置方式优先级（从高到低）：
## 1. JVM 参数：-DLOG_HOME=./your-logs
## 2. IDE Run Configuration 环境变量：LOG_HOME=./your-logs
## 3. 系统环境变量：export LOG_HOME=./your-logs
##
## 如无特殊需求，可不配置，使用默认值 ./travel-server/logs
## LOG_HOME=./travel-server/logs
