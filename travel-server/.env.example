# ===== WayTrip 后端环境配置 =====
# 将此文件复制为 .env 并填入实际值
# cp .env.example .env

# ----- 数据库配置 -----
DB_HOST=localhost
DB_PORT=3306
DB_NAME=waytrip_db
DB_USERNAME=root
DB_PASSWORD=

# ----- Redis 配置 -----
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# ----- JWT 配置 -----
# 用于签名 Token 的密钥（建议至少 32 个字符）
JWT_SECRET=

# ----- 微信小程序配置 -----
# 从 https://mp.weixin.qq.com/ 获取
# 同时需要在 travel-miniapp/src/manifest.json 中更新 appid
WECHAT_APPID=
WECHAT_SECRET=

# ----- 文件上传配置 -----
# 上传目录支持自定义，建议优先使用绝对路径，避免因启动工作目录不同导致相对路径解析结果不一致。
# 如果使用相对路径：
# - 从 WayTrip 根目录启动时，相对 WayTrip 根目录解析
# - 从 travel-server 目录启动时，相对 travel-server 目录解析
# 当前示例值使用绝对路径占位写法，实际使用时请替换为你的本地或服务器路径。
UPLOAD_PATH=E:/path/to/waytrip/uploads
